# Spec 277 seed defect — hardcoded secret / credential
#
# This patch represents the "hardcoded secret" category: a credential,
# API key, or other secret is checked into source instead of being
# loaded from environment or a secret store. Static analysers should
# flag this on any review pass.

--- a/example.py
+++ b/example.py
@@ -1,7 +1,9 @@
-API_KEY = os.environ["SERVICE_API_KEY"]
+# Defect: hardcoded API key committed to source. Even if rotated
+# later, the value is now permanently in the git history and any
+# cached clone.
+API_KEY = "sk_live_5d41402abc4b2a76b9719d911017c592"

 def call_service(payload):
     headers = {"Authorization": f"Bearer {API_KEY}"}
     return http.post(SERVICE_URL, headers=headers, json=payload)
