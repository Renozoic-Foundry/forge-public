{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "description": "Versioned library documentation lookup. Use resolve-library-id then get-library-docs for any third-party library before writing code against it."
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "description": "Fetch any URL and return it as markdown. Use for one-off documentation lookups, RFC text, or any URL not covered by Context7."
    }
  }
}
