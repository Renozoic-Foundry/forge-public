# FORGE eol policy (shipped to consumer projects via Copier).
# Pins line endings so cross-platform checkouts stay byte-stable — in particular so a
# SIGNED plugin payload manifest verifies identically on Windows (autocrlf=true) and Linux.

# Auto-detect text files and normalize line endings.
* text=auto

# Force LF for shell + config text so Windows autocrlf doesn't introduce CRLF.
*.sh text eol=lf
.shellcheckrc text eol=lf
*.md text eol=lf
*.json text eol=lf

# Plugin payload signing (Spec 488/517): the manifest is signed over LF bytes — pin it LF on
# every checkout; the detached minisign signature is binary (no eol conversion). Without these,
# a Windows checkout CRLFs the manifest and the SessionStart integrity hook's minisign -V fails.
.claude-plugin/payload-manifest.txt text eol=lf
*.minisig binary

# ============================================================================
# Spec 529 — merge-safe shared artifacts (union attrs for parallel-lane writes).
# union ONLY for append-only, line-oriented, order-tolerant streams; every entry
# carries its safety argument. Spec files / signals / scratchpad / session logs /
# backlog / CHANGELOG carry NO union attr (operator-owned or frontmatter-bearing).
# Revision-Log conflicts: manual convention in docs/process-kit/parallelism-guide.md.
# ============================================================================
# activity-log.jsonl: agent-writable cross-lane feed; self-contained JSON lines.
docs/sessions/activity-log.jsonl merge=union
# security-gate.jsonl: append-only gate-verdict ledger; order-tolerant records.
.forge/state/security-gate.jsonl merge=union
# agent-file-registry.md: single-line role-log appends with embedded timestamps.
docs/sessions/agent-file-registry.md merge=union
# doctor-history.jsonl: append-only JSONL from every doctor run across worktrees.
docs/sessions/doctor-history.jsonl merge=union
